# ============================================================
# KamerSync - Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# --- Backend API ---
API_BASE_URL=http://localhost:3000/api/v1

# --- Google Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Mapbox (for flutter_map if using Mapbox tiles) ---
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# --- Firebase (configured via google-services.json / GoogleService-Info.plist) ---
# No additional Firebase keys needed in .env; configure via Firebase console

# --- JWT Secret (Backend only) ---
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# --- Database (Backend only) ---
DATABASE_URL=postgresql://username:password@localhost:5432/kamer_sync_db

# --- Cloud Storage (Backend only) ---
AWS_S3_BUCKET=your_s3_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
